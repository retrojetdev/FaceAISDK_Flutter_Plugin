<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.faceAI.face_ai_sdk">

    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="com.android.vending.CHECK_LICENSE" />

    <application
        android:largeHeap="true"
        android:hardwareAccelerated="true">
        <activity
            android:name="com.faceAI.face_ai_sdk.SysCamera.verify.FaceVerificationActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FaceAISDK.Fullscreen" />

        <activity
            android:name="com.faceAI.face_ai_sdk.SysCamera.verify.LivenessDetectActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FaceAISDK.Fullscreen" />

        <activity
            android:name="com.faceAI.face_ai_sdk.SysCamera.addFace.AddFaceFeatureActivity"
            android:exported="false"
            android:theme="@style/FaceAITheme" />
    </application>

</manifest>
